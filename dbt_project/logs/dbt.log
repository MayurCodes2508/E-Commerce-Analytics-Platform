       b.delivered_at
FROM base b
JOIN `intense-pixel-490219-h2`.`dev_core`.`dim_date` dd_shipped
ON DATE(b.shipped_at) = dd_shipped.date
LEFT JOIN `intense-pixel-490219-h2`.`dev_core`.`dim_date` dd_delivered
ON DATE(b.delivered_at) = dd_delivered.date
    ) as model_subq
    );
  
